# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

# Required — your MangaBaka personal access token
MANGABAKA_TOKEN=mb-your-token-here

# Optional — Pushover credentials (can also be set via the Settings UI)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Optional — how often to poll for new chapters (default: 6 hours)
POLL_INTERVAL_HOURS=6

# Optional — path to the SQLite database inside the container (default shown)
DB_PATH=/data/manga_tracker.db
